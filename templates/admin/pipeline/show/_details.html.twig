{% set pipeline = resource %}

<table class="ui celled striped table">
    <tbody>
    <tr>
        <td>{{ 'bout_de_code_sylius_etl_plugin.grid.workflow'|trans }}</td>
        <td>
            <a href="{{ path('bout_de_code_sylius_etl_plugin_admin_workflow_index', { id: pipeline.workflow.id }) }}">
                {{ pipeline.workflow.name }}
            </a>
        </td>
    </tr>
    <tr>
        <td>{{ 'bout_de_code_sylius_etl_plugin.grid.status'|trans }}</td>
        <td>
            {% include '@BoutDeCodeSyliusETLPlugin/admin/grid/field/status.html.twig' with { data: pipeline.status } %}
        </td>
    </tr>
    <tr>
        <td>{{ 'bout_de_code_sylius_etl_plugin.grid.created_at'|trans }}</td>
        <td>{{ pipeline.createdAt|date }}</td>
    </tr>
    <tr>
        <td>{{ 'bout_de_code_sylius_etl_plugin.grid.scheduled_at'|trans }}</td>
        <td>{{ pipeline.scheduledAt ? pipeline.scheduledAt|date : '-' }}</td>
    </tr>
    <tr>
        <td>{{ 'bout_de_code_sylius_etl_plugin.grid.started_at'|trans }}</td>
        <td>{{ pipeline.startedAt ? pipeline.startedAt|date : '-' }}</td>
    </tr>
    <tr>
        <td>{{ 'bout_de_code_sylius_etl_plugin.grid.finished_at'|trans }}</td>
        <td>{{ pipeline.finishedAt ? pipeline.finishedAt|date : '-' }}</td>
    </tr>
    </tbody>
</table>
